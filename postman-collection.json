{
  "info": {
    "name": "Session Logger API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "List Clients",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/clients",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Create Client (Hourly)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/clients",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Corp\",\n  \"billingType\": \"HOURLY\",\n  \"hourlyRate\": 150,\n  \"monthlyBudget\": 3000,\n  \"notes\": \"Enterprise client\",\n  \"tags\": [\"enterprise\"]\n}"
            }
          }
        },
        {
          "name": "Create Client (Fixed)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/clients",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Design Co\",\n  \"billingType\": \"FIXED\",\n  \"fixedRate\": 200,\n  \"monthlyBudget\": 1600\n}"
            }
          }
        },
        {
          "name": "Get Client",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/clients/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Client",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/clients/:id",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hourlyRate\": 175,\n  \"monthlyBudget\": 4000\n}"
            }
          }
        },
        {
          "name": "Delete Client",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/clients/:id",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "Start Session",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/sessions/start",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"<client_id>\"\n}"
            }
          }
        },
        {
          "name": "End Session",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/sessions/end",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"<session_id>\",\n  \"notes\": \"Discussed project roadmap\"\n}"
            }
          }
        },
        {
          "name": "Get Active Sessions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/sessions/active",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "List Sessions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/sessions?page=1&limit=50",
              "query": [
                { "key": "clientId", "value": "", "disabled": true },
                { "key": "startDate", "value": "2025-01-01", "disabled": true },
                { "key": "endDate", "value": "2025-01-31", "disabled": true },
                { "key": "status", "value": "COMPLETED", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "50" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Abandon Session",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/sessions/:id/abandon",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/reports/dashboard",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Monthly Report",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reports/monthly?month=2025-01",
              "query": [
                { "key": "month", "value": "2025-01" },
                { "key": "clientId", "value": "", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Export CSV",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reports/export?month=2025-01",
              "query": [
                { "key": "month", "value": "2025-01" },
                { "key": "clientId", "value": "", "disabled": true }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
